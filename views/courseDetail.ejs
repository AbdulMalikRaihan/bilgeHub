<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= course.name %></title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body class="bg-light">
    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/home"> 🎓 BilgeHub </a>

        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-4">
            <li class="nav-item">
              <a class="nav-link active" href="/home"> All Course </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/instructors"> Instructor </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/my-learning"> My Learning </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Hero -->

    <section class="text-white py-5" style="background: #343a40">
      <div class="container">
        <div class="row">
          <div class="col-lg-8">
            <h1 class="display-5 fw-bold mb-3"><%= course.name %></h1>

            <p class="lead text-white-50"><%= course.description %></p>

            <hr class="border-secondary my-4" />

            <h4 class="fw-bold mb-4">📚 Course Materials</h4>

            <div class="row">
              <% materials.forEach(material=>{ %>

              <div class="col-md-6 mb-3">
                <div class="d-flex">
                  <i class="bi bi-check-circle-fill text-success me-3"></i>

                  <span> <%= material %> </span>
                </div>
              </div>

              <% }) %>
            </div>

            <div class="d-flex align-items-center">
              <img
                src="<%= course.Instructor.imageUrl %>"
                class="rounded-circle border border-2 me-3"
                width="55"
                height="55"
                style="object-fit: cover"
              />

              <div>
                <small class="text-secondary"> Created by </small>

                <div class="fw-semibold"><%= course.Instructor.fullName %></div>
              </div>
            </div>
          </div>

          <!-- Right Card -->

          <div class="col-lg-4">
            <div class="card shadow-lg rounded-4 border-0">
              <img
                src="<%= course.imageUrl %>"
                class="card-img-top"
                style="height: 250px; object-fit: cover"
              />

              <div class="card-body p-4">
                <!-- Course Information -->

                <h5 class="fw-bold mb-3">Course Information</h5>
                <hr />

                <ul class="list-group list-group-flush mb-4">
                  <li
                    class="list-group-item d-flex justify-content-between align-items-center"
                  >
                    <span>Category</span>

                    <strong><%= course.Category.name %></strong>
                  </li>

                  <li
                    class="list-group-item d-flex justify-content-between align-items-center"
                  >
                    <span>Level</span>

                    <span class="badge bg-primary"> <%= course.level %> </span>
                  </li>

                  <li
                    class="list-group-item d-flex justify-content-between align-items-center"
                  >
                    <span>Duration</span>

                    <strong> <%= course.formattedDuration %> </strong>
                  </li>
                </ul>

                <hr class="my-4" />

                <% if(!isEnrolled){ %>

                  <h2 class="fw-bold text-success mb-4">
                  
                  <%= formatRupiah(course.price) %>
                  
                  </h2>
                  
                  <form
                  action="/courses/<%= course.id %>/enroll"
                  method="POST">
                  
                  <button
                  class="btn btn-dark rounded-pill w-100">
                  
                  Enroll Now
                  
                  </button>
                  
                  </form>
                  
                  <% } else { %>

                    <h5 class="fw-bold mb-3">Your Progress</h5>
                    
                    <div class="progress mb-4">
                      <div
                        class="progress-bar bg-success"
                        style="width:<%= enrollment.progress %>%"
                      >
                        <%= enrollment.progress %>%
                      </div>
                    </div>
                    
                    <% if (enrollment.progress === 100) { %>
                      <a href="/certificate/<%= enrollment.id %>" class="btn btn-success rounded-pill w-100">
                        <i class="bi bi-award"></i>
                        Certificate
                      </a>
                    <% } else { %>
                      <a href="/my-learning/<%= course.id %>" class="btn btn-dark w-100">
                        Continue Learning
                      </a>
                    <% } %>
                    
                    <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <footer class="bg-dark text-white py-3">
      <div class="container text-center">
        © 2026 BilgeHub. All Rights Reserved.
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
