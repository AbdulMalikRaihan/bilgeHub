<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Course</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/home">🎓 BilgeHub</a>

        <button
          class="navbar-toggler"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-4">
            <li class="nav-item">
              <a class="nav-link" href="/home">All Courses</a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/instructors">Instructor</a>
            </li>

            <li class="nav-item">
              <a class="nav-link active" href="/my-courses">My Courses</a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/courses/add">Add Course</a>
            </li>
          </ul>

          <div class="d-flex align-items-center ms-auto gap-3">
            <form action="/my-courses" method="GET" class="d-flex">
              <input
                class="form-control"
                type="search"
                name="search"
                placeholder="Search course..."
              />

              <button class="btn btn-outline-light ms-2">
                <i class="bi bi-search"></i>
              </button>
            </form>

            <div class="dropdown">
              <button
                class="btn btn-outline-light rounded-circle"
                data-bs-toggle="dropdown"
              >
                <i class="bi bi-person-circle fs-4"></i>
              </button>

              <ul class="dropdown-menu dropdown-menu-end shadow">
                <li>
                  <h6 class="dropdown-header"><%= user.role %></h6>
                </li>

                <li>
                  <a class="dropdown-item" href="/profile/edit">
                    <i class="bi bi-pencil-square me-2"></i>
                    Edit Profile
                  </a>
                </li>

                <li><hr class="dropdown-divider" /></li>

                <li>
                  <a class="dropdown-item text-danger" href="/logout">
                    <i class="bi bi-box-arrow-right me-2"></i>
                    Logout
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <section class="text-white py-5" style="background: #343a40">
      <div class="container">
        <h1 class="display-5 fw-bold">My Courses</h1>

        <p class="lead text-white-50">
          Manage your published courses and reach more students.
        </p>
      </div>
    </section>

    <% if(request.query.success){ %>

    <div class="container mt-4">
      <div class="alert alert-success alert-dismissible fade show">
        <%= request.query.success %>

        <button class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    </div>

    <% } %>

    <section class="py-4">
      <div class="container">
        <div class="row">
          <div class="col-md-4">
            <div class="card shadow-sm border-0">
              <div class="card-body text-center">
                <h1 class="fw-bold text-primary"><%= courses.length %></h1>

                <p class="text-muted mb-0">Total Courses</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-5">
      <div class="container">
        <div class="row g-4">
          <% courses.forEach(course=>{ %>

          <div class="col-lg-4">
            <div class="card border-0 shadow h-100">
              <img
                src="<%= course.imageUrl %>"
                class="card-img-top"
                style="height: 220px; object-fit: cover"
              />

              <div class="card-body d-flex flex-column">
                <span class="badge bg-primary mb-2"> <%= course.level %> </span>

                <h5 class="fw-bold"><%= course.name %></h5>

                <p class="text-muted small"><%= course.Category.name %></p>

                <div class="mb-3">
                  <div class="small text-secondary">
                    🕒 <%= course.formattedDuration %>
                  </div>

                  <div class="small text-secondary">
                    💰 <%= formattedPrice(course.price) %>
                  </div>
                </div>

                <div class="mt-auto d-flex gap-2">
                  <a
                    href="/courses/<%= course.id %>/edit"
                    class="btn btn-warning flex-fill"
                  >
                    Edit
                  </a>

                  <a
                    href="/courses/<%= course.id %>/delete"
                    class="btn btn-danger flex-fill"
                  >
                    Delete
                  </a>
                </div>
              </div>
            </div>
          </div>

          <% }) %>
        </div>
      </div>
    </section>

    <% if(courses.length===0){ %>

    <div class="text-center py-5">
      <h2>No Course Yet</h2>

      <p class="text-muted">Start publishing your first course.</p>

      <a href="/courses/add" class="btn btn-dark"> Create Course </a>
    </div>

    <% } %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
