<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Complete Profile | BilgeHub</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body class="bg-light">
    <!-- Navbar -->

    <nav class="navbar navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/"> 🎓 BilgeHub </a>
      </div>
    </nav>

    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-7">
          <div class="card border-0 shadow-lg rounded-4">
            <div class="card-body p-5">
              <div class="text-center mb-4">
                <i class="bi bi-person-circle display-3 text-dark"></i>

                <h2 class="fw-bold mt-3">Complete Your Profile</h2>

                <p class="text-muted">
                  Complete your profile before using BilgeHub.
                </p>
              </div>

              <form action="/user-profile/<%= user.id %>" method="POST">
                <!-- Full Name -->

                <div class="mb-3">
                  <label class="form-label"> Full Name </label>

                  <input
                    type="text"
                    name="fullName"
                    class="form-control form-control-lg"
                    placeholder="Enter your full name"
                  />
                  <% if(errors.fullName){ %>

                  <small class="text-danger"> * <%= errors.fullName %> </small>

                  <% } %>
                </div>

                <% if(user.role==="Student"){ %>

                <!-- Phone -->

                <div class="mb-3">
                  <label class="form-label"> Phone Number </label>

                  <input
                    type="text"
                    name="phoneNumber"
                    class="form-control form-control-lg"
                    placeholder="ex: 0812xx"
                  />
                  <% if(errors.phoneNumber){ %>

                  <small class="text-danger">
                    * <%= errors.phoneNumber %>
                  </small>

                  <% } %>
                </div>

                <!-- DOB -->

                <div class="mb-4">
                  <label class="form-label"> Date of Birth </label>

                  <input
                    type="date"
                    name="dateOfBirth"
                    class="form-control form-control-lg"
                  />
                  <% if(errors.dateOfBirth){ %>

                  <small class="text-danger">
                    * <%= errors.dateOfBirth %>
                  </small>

                  <% } %>
                </div>

                <% }else{ %>

                <!-- Expertise -->

                <div class="mb-3">
                  <label class="form-label"> Expertise </label>

                  <input
                    type="text"
                    name="expertise"
                    class="form-control form-control-lg"
                    placeholder="Ex: Software Engineer"
                  />
                  <% if(errors.expertise){ %>

                  <small class="text-danger"> * <%= errors.expertise %> </small>

                  <% } %>
                </div>

                <!-- Experience -->

                <div class="mb-3">
                  <label class="form-label"> Years Experience </label>

                  <input
                    type="number"
                    name="yearsExperience"
                    class="form-control form-control-lg"
                    placeholder="1"
                  />
                  <% if(errors.yearsExperience){ %>

                  <small class="text-danger">
                    * <%= errors.yearsExperience %>
                  </small>

                  <% } %>
                </div>

                <!-- Image -->

                <div class="mb-3">
                  <label class="form-label"> Profile Image URL </label>

                  <input
                    type="text"
                    name="imageUrl"
                    class="form-control form-control-lg"
                    placeholder="https://..."
                  />
                  <% if(errors.imageUrl){ %>

                  <small class="text-danger"> * <%= errors.imageUrl %> </small>

                  <% } %>
                </div>

                <!-- Bio -->

                <div class="mb-4">
                  <label class="form-label"> Biography </label>

                  <textarea
                    class="form-control"
                    rows="5"
                    name="bio"
                    placeholder="Tell students about yourself..."
                  ></textarea>
                  <% if(errors.bio){ %>

                  <small class="text-danger"> * <%= errors.bio %> </small>

                  <% } %>
                </div>

                <% } %>

                <div class="d-grid">
                  <button class="btn btn-dark btn-lg rounded-pill">
                    Save Profile
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
