<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BilgeHub</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <!-- Logo -->

        <a class="navbar-brand fw-bold" href="/home"> 🎓 BilgeHub </a>

        <button
          class="navbar-toggler"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <!-- Left Menu -->

          <ul class="navbar-nav ms-4">
            <% if(user.role==="Student"){ %>

            <li class="nav-item">
              <a class="nav-link active" href="/home"> All Courses </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/instructors"> Instructor </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/my-learning"> My Learning </a>
            </li>

            <% } else { %>

            <li class="nav-item">
              <a class="nav-link active" href="/home"> All Courses </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/instructors"> Instructor </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/my-courses"> My Courses </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/courses/add"> Add Course </a>
            </li>

            <% } %>
          </ul>

          <!-- Right -->

          <div class="d-flex align-items-center ms-auto gap-3">
            <!-- Search -->
            <form action="/home" method="GET" class="d-flex">
              <input
                class="form-control"
                type="search"
                name="search"
                placeholder="Search course..."
                value="<%= search || '' %>"
              />

              <button class="btn btn-outline-light ms-2">
                <i class="bi bi-search"></i>
              </button>
            </form>

            <!-- Profile -->
            <div class="dropdown">
              <button
                class="btn btn-outline-light rounded-circle"
                data-bs-toggle="dropdown"
              >
                <i class="bi bi-person-circle fs-4"></i>
              </button>

              <ul class="dropdown-menu dropdown-menu-end shadow">
                <li>
                  <h6 class="dropdown-header"><%= user.role %></h6>
                </li>

                <li>
                  <a class="dropdown-item" href="/profile/edit">
                    <i class="bi bi-pencil-square me-2"></i>
                    Edit Profile
                  </a>
                </li>

                <li><hr class="dropdown-divider" /></li>

                <li>
                  <a class="dropdown-item text-danger" href="/logout">
                    <i class="bi bi-box-arrow-right me-2"></i>
                    Logout
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="text-white py-5 mb-5" style="background: #343a40">
      <div class="container text-center">
        <h1 class="display-4 fw-bold">Learn New Skills Anytime</h1>

        <p class="lead">Discover online courses from industry experts.</p>
      </div>
    </section>

    <!-- Category -->
    <div class="container my-4">
      <div class="d-flex justify-content-center flex-wrap gap-2">
        <a
          href="/home"
          class="btn <%= !selectedCategory ? 'btn-dark' : 'btn-outline-dark' %> rounded-pill"
        >
          All
        </a>

        <% categories.forEach(category => { %>

        <a
          href="/home?category=<%= category.id %>"
          class="btn <%= selectedCategory == category.id ? 'btn-dark' : 'btn-outline-dark' %> rounded-pill"
        >
          <%= category.name %>
        </a>

        <% }) %>
      </div>
    </div>

    <!-- Courses -->
    <div class="container mb-5">
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        <% if(courses.length === 0){ %>

        <div class="col-12 text-center">
          <h3>No Course Found</h3>
        </div>

        <% } %> <% courses.forEach(course => { %>

        <div class="col">
          <div class="card h-100 shadow-sm">
            <img
              src="<%= course.imageUrl %>"
              class="card-img-top"
              alt="<%= course.name %>"
              style="height: 220px; object-fit: cover"
            />

            <div class="card-body d-flex flex-column">
              <!-- Level -->
              <div class="mb-3">
                <span
                  class="badge <%= course.level === 'Beginner' ? 'bg-primary' : course.level === 'Intermediate' ? 'bg-warning text-dark' : 'bg-danger' %>"
                >
                  <%= course.level %>
                </span>
              </div>

              <!-- Title -->
              <h5 class="fw-bold" style="min-height: 64px">
                <%= course.name %>
              </h5>

              <!-- Instructor -->
              <div class="d-flex align-items-center mb-3">
                <img
                  src="<%= course.Instructor.imageUrl %>"
                  class="rounded-circle me-3"
                  width="45"
                  height="45"
                  style="object-fit: cover"
                />

                <div>
                  <div class="fw-semibold">
                    <%= course.Instructor.fullName %>
                  </div>

                  <small class="text-muted">
                    <%= course.Category.name %>
                  </small>
                </div>
              </div>

              <!-- Description -->
              <p class="text-secondary small" style="min-height: 96px">
                <%= course.description.length > 100 ?
                course.description.substring(0,100) + "..." : course.description
                %>
              </p>

              <!-- Bottom -->
              <div class="mt-auto">
                <h4 class="fw-bold text-success">
                  <%= formatRupiah(course.price) %>
                </h4>

                <a
                  href="/courses/<%= course.id %>"
                  class="btn btn-dark w-100 mt-3"
                >
                  View Course
                </a>
              </div>
            </div>
          </div>
        </div>

        <% }) %>
      </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white py-3">
      <div class="container text-center">
        © 2026 BilgeHub. All Rights Reserved.
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
