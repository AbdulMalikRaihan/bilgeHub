<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BilgeHub</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body class="bg-light">
    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <!-- Logo -->

        <a class="navbar-brand fw-bold" href="/"> 🎓 BilgeHub </a>

        <button
          class="navbar-toggler"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <!-- Left Menu -->

          <ul class="navbar-nav ms-4">
            <% if(user.role==="Student"){ %>

            <li class="nav-item">
              <a class="nav-link" href="/home"> All Courses </a>
            </li>

            <li class="nav-item">
              <a class="nav-link active" href="/instructors"> Instructor </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/my-learning"> My Learning </a>
            </li>

            <% } else { %>

            <li class="nav-item">
              <a class="nav-link" href="/home"> All Courses </a>
            </li>

            <li class="nav-item">
              <a class="nav-link active" href="/instructors"> Instructor </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/my-courses"> My Courses </a>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/courses/add"> Add Course </a>
            </li>

            <% } %>
          </ul>

          <!-- Right -->

          <div class="d-flex align-items-center ms-auto gap-3">
            <!-- Search -->
            <form action="/instructors" method="GET" class="d-flex">
              <input
                class="form-control"
                type="search"
                name="search"
                placeholder="Search instructor..."
                value="<%= search || '' %>"
              />

              <button class="btn btn-outline-light ms-2">
                <i class="bi bi-search"></i>
              </button>
            </form>

            <!-- Profile -->
            <div class="dropdown">
              <button
                class="btn btn-outline-light rounded-circle"
                data-bs-toggle="dropdown"
              >
                <i class="bi bi-person-circle fs-4"></i>
              </button>

              <ul class="dropdown-menu dropdown-menu-end shadow">
                <li>
                  <h6 class="dropdown-header"><%= user.role %></h6>
                </li>

                <li>
                  <a class="dropdown-item" href="/profile/edit">
                    <i class="bi bi-pencil-square me-2"></i>
                    Edit Profile
                  </a>
                </li>

                <li><hr class="dropdown-divider" /></li>

                <li>
                  <a class="dropdown-item text-danger" href="/logout">
                    <i class="bi bi-box-arrow-right me-2"></i>
                    Logout
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero -->

    <section class="text-white py-5 mb-5" style="background: #343a40">
      <div class="container text-center">
        <h1 class="display-4 fw-bold">Meet Our Instructors</h1>

        <p class="lead">
          Learn directly from experienced industry professionals.
        </p>
      </div>
    </section>

    <!-- Instructor -->

    <div class="container mb-5">
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% instructors.forEach(instructor=>{ %>

        <div class="col">
          <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
              <!-- Profile -->

              <div class="text-center">
                <img
                  src="<%= instructor.imageUrl %>"
                  class="rounded-circle border border-3 mb-3"
                  width="120"
                  height="120"
                  style="object-fit: cover"
                />

                <h3 class="fw-bold mb-2"><%= instructor.fullName %></h3>

                <span class="badge bg-dark px-3 py-2">
                  <%= instructor.expertise %>
                </span>

                <p class="text-muted mt-3 mb-0">
                  <%= instructor.yearsExperience %> Years Experience
                </p>
              </div>

              <hr />

              <!-- Bio -->
              <p class="fst-italic text-secondary">"<%= instructor.bio %>"</p>

              <hr />

              <!-- Courses Header -->

              <div
                class="d-flex justify-content-between align-items-center mb-3"
              >
                <h5 class="fw-bold mb-0">📚 Courses</h5>

                <span class="badge bg-dark rounded-pill">
                  Total <%= instructor.Courses.length %>
                </span>
              </div>

              <% if(instructor.Courses.length){ %>

              <div class="list-group list-group-flush">
                <% instructor.Courses.forEach(course=>{ %>

                <div class="list-group-item px-0 py-3">
                  <div
                    class="d-flex justify-content-between align-items-center mb-2"
                  >
                    <div>
                      <div class="fw-semibold"><%= course.name %></div>
                    </div>

                    <span
                      class="badge <%= course.level === 'Beginner' ? 'bg-primary' : course.level === 'Intermediate' ? 'bg-warning text-dark' : 'bg-danger' %>"
                    >
                      <%= course.level %>
                    </span>
                  </div>

                  <a
                    href="/courses/<%= course.id %>"
                    class="btn btn-outline-dark btn-sm"
                  >
                    View Course
                  </a>
                </div>

                <% }) %>
              </div>

              <% } else { %>

              <div class="alert alert-light border text-center">
                No courses available.
              </div>

              <% } %>
            </div>
          </div>
        </div>

        <% }) %>
      </div>
    </div>

    <!-- Footer -->

    <footer class="bg-dark text-white py-3">
      <div class="container text-center">
        © 2026 BilgeHub. All Rights Reserved.
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
