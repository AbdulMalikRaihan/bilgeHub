<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register | BilgeHub</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />
  </head>

  <body class="bg-light">
    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/"> 🎓 BilgeHub </a>
      </div>
    </nav>

    <!-- Register -->

    <div class="container py-5">
      <div class="row justify-content-center align-items-center g-5">
        <!-- Illustration -->

        <div class="col-lg-6 d-none d-lg-block">
          <img
            src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=900"
            class="img-fluid rounded-4 shadow"
            alt="Register"
          />
        </div>

        <!-- Form -->

        <div class="col-lg-5">
          <div class="card border-0 shadow-lg rounded-4">
            <div class="card-body p-5">
              <div class="text-center mb-4">
                <h2 class="fw-bold">Create Account</h2>

                <p class="text-muted">Start learning with BilgeHub today.</p>
              </div>

              <form action="/register" method="POST">
                <div class="mb-3">
                  <label class="form-label"> Email </label>

                  <input
                    type="text"
                    name="email"
                    class="form-control form-control-lg"
                    placeholder="Enter your email"
                  />
                  <% if(errors?.email){ %>

                  <small class="text-danger"> * <%= errors.email %> </small>

                  <% } %>
                </div>

                <div class="mb-3">
                  <label class="form-label"> Password </label>

                  <input
                    type="password"
                    name="password"
                    class="form-control form-control-lg"
                    placeholder="Create password"
                  />
                  <% if(errors?.password){ %>

                  <small class="text-danger"> * <%= errors.password %> </small>

                  <% } %>
                </div>

                <div class="mb-4">
                  <label class="form-label"> Register As </label>

                  <div class="d-flex gap-4">
                    <div class="form-check">
                      <input
                        class="form-check-input"
                        type="radio"
                        name="role"
                        id="student"
                        value="Student"
                      />

                      <label class="form-check-label" for="student">
                        Student
                      </label>
                    </div>

                    <div class="form-check">
                      <input
                        class="form-check-input"
                        type="radio"
                        name="role"
                        id="instructor"
                        value="Instructor"
                      />

                      <label class="form-check-label" for="instructor">
                        Instructor
                      </label>
                    </div>
                  </div>
                  <% if(errors?.role){ %>

                  <small class="text-danger"> * <%= errors.role %> </small>

                  <% } %>
                </div>

                <div class="d-grid mb-4">
                  <button class="btn btn-dark btn-lg rounded-pill">
                    Create Account
                  </button>
                </div>
              </form>

              <div class="text-center">
                <span class="text-muted"> Already have an account? </span>

                <a href="/login" class="text-decoration-none fw-semibold">
                  Login
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
