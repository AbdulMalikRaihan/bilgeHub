<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Edit Course | BilgeHub</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body class="bg-light">
    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/home"> 🎓 BilgeHub </a>

        <button
          class="navbar-toggler"
          data-bs-toggle="collapse"
          data-bs-target="#navbar"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbar">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a href="/home" class="nav-link"> All Courses </a>
            </li>

            <li class="nav-item">
              <a href="/my-courses" class="nav-link"> My Courses </a>
            </li>

            <li class="nav-item">
              <a href="/courses/add" class="nav-link active"> Add Course </a>
            </li>

            <li class="nav-item">
              <a href="/logout" class="nav-link"> Logout </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Hero -->

    <section class="bg-dark text-white py-5 mb-5">
      <div class="container">
        <h1 class="display-5 fw-bold">Edit Course</h1>

        <p class="lead text-white-50">
          Create a new course and start sharing your knowledge.
        </p>
      </div>
    </section>

    <div class="container mb-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card shadow border-0">
            <div class="card-body p-5">
              <h3 class="fw-bold mb-4">Course Information</h3>

              <form action="/courses/<%= course.id %>/edit" method="POST">
                <!-- Name -->

                <div class="mb-4">
                  <label class="form-label fw-semibold"> Course Name </label>

                  <input
                    type="text"
                    name="name"
                    class="form-control form-control-lg"
                    value="<%= course.name %>"
                  />
                  <% if(errors?.name){ %>
                    <small class="text-danger">
                      * <%= errors.name %>
                    </small>
                    <% } %>
                </div>

                <!-- Description -->

                <div class="mb-4">
                  <label class="form-label fw-semibold"> Description </label>

                  <textarea
                    rows="6"
                    name="description"
                    class="form-control"
                  ><%= course.description %></textarea>
                  <% if(errors?.description){ %>
                    <small class="text-danger">
                      * <%= errors.description %>
                    </small>
                    <% } %>
                </div>

                <!-- Material -->

                <div class="mb-4">
                  <label class="form-label fw-semibold">
                    Course Materials
                  </label>

                  <textarea
                    rows="10"
                    name="material"
                    class="form-control"><%= course.material %></textarea>
                    <% if(errors?.material){ %>
                      <small class="text-danger">
                        * <%= errors.material %>
                      </small>
                      <% } %>
                </div>

                <!-- Category -->

                <div class="mb-4">
                  <label class="form-label fw-semibold"> Category </label>

                  <select name="CategoryId" class="form-select">
                    <% categories.forEach(category=>{ %>

                    <option value="<%= category.id %>" <%= course.CategoryId===category.id ? "selected" : "" %>>>
                      <%= category.name %>
                    </option>

                    <% }) %>
                  </select>
                  <% if(errors?.CategoryId){ %>
                    <small class="text-danger">
                      * <%= errors.CategoryId %>
                    </small>
                    <% } %>
                </div>

                <div class="row">
                  <div class="col-md-4 mb-4">
                    <label class="form-label fw-semibold"> Level </label>

                    <select name="level" class="form-select">
                      <option value="Beginner"
                      <%= course.level==="Beginner" ? "selected" : "" %>>Beginner</option>

                      <option value="Intermediate"
                      <%= course.level==="Intermediate" ? "selected" : "" %>>Intermediate</option>

                      <option value="Advanced"
                      <%= course.level==="Advanced" ? "selected" : "" %>>Advanced</option>
                    </select>
                    <% if(errors?.level){ %>
                      <small class="text-danger">
                        * <%= errors.level %>
                      </small>
                      <% } %>
                  </div>

                  <div class="col-md-4 mb-4">
                    <label class="form-label fw-semibold" >
                      Duration (Hours)
                    </label>

                    <input type="number" class="form-control" name="duration" value="<%= course.duration %>"/>
                    <% if(errors?.duration){ %>
                      <small class="text-danger">
                        * <%= errors.duration %>
                      </small>
                      <% } %>
                  </div>

                  <div class="col-md-4 mb-4">
                    <label class="form-label fw-semibold"  > Price </label>

                    <input type="number" class="form-control" name="price" value="<%= course.price %>"/>
                  </div>
                  <% if(errors?.price){ %>
                    <small class="text-danger">
                      * <%= errors.price %>
                    </small>
                    <% } %>
                </div>

                <!-- Image -->

                <div class="mb-5">
                  <label class="form-label fw-semibold"> Image URL </label>

                  <input type="text" name="imageUrl" class="form-control" 
                  value="<%= course.imageUrl %>"/>
                  <% if(errors?.imageUrl){ %>
                    <small class="text-danger">
                      * <%= errors.imageUrl %>
                    </small>
                    <% } %>
                </div>

                <div class="d-flex justify-content-between">
                  <a href="/my-courses" class="btn btn-outline-secondary px-4">
                    Cancel
                  </a>

                  <button class="btn btn-dark px-5">Update Course</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
