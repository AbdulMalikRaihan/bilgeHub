<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BilgeHub</title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body class="bg-light">
    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold fs-3" href="/"> 🎓 BilgeHub </a>

        <div class="ms-auto">
          <a href="/login" class="btn btn-outline-light rounded-pill px-4 me-2">
            Login
          </a>

          <a href="/register" class="btn btn-warning rounded-pill px-4">
            Register
          </a>
        </div>
      </div>
    </nav>

    <!-- Hero -->

    <section
      class="text-white text-center d-flex align-items-center"
      style="
        height: 90vh;
        background: linear-gradient(rgba(0, 0, 0, 0.65), rgba(0, 0, 0, 0.65)),
          url('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1600');
        background-size: cover;
        background-position: center;
      "
    >
      <div class="container">
        <h1 class="display-2 fw-bold mb-4">
          Learn Programming
          <br />
          Without Limits
        </h1>

        <p class="lead mb-5">
          Master Web Development, Mobile Development, Artificial Intelligence,
          Data Science, and more with professional instructors.
        </p>

        <a
          href="/register"
          class="btn btn-warning btn-lg rounded-pill px-5 me-3"
        >
          Start Learning
        </a>
      </div>
    </section>

    <!-- Features -->

    <section class="py-5">
      <div class="container">
        <div class="row g-4">
          <div class="col-md-3">
            <div class="card shadow border-0 h-100">
              <div class="card-body text-center">
                <i class="bi bi-journal-code display-3 text-primary"></i>

                <h3 class="mt-3">Approved</h3>

                <p class="mb-0">Programming Courses</p>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card shadow border-0 h-100">
              <div class="card-body text-center">
                <i class="bi bi-person-video3 display-3 text-success"></i>

                <h3 class="mt-3">Expert</h3>

                <p class="mb-0">Professional Instructor</p>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card shadow border-0 h-100">
              <div class="card-body text-center">
                <i class="bi bi-award display-3 text-warning"></i>

                <h3 class="mt-3">Certificate</h3>

                <p class="mb-0">Finish courses and earn certificates</p>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card shadow border-0 h-100">
              <div class="card-body text-center">
                <i class="bi bi-laptop display-3 text-danger"></i>

                <h3 class="mt-3">Project</h3>

                <p class="mb-0">Hands-on practice</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories -->

    <section class="py-5 bg-white">
      <div class="container">
        <h2 class="fw-bold text-center mb-5">Popular Categories</h2>

        <div class="row g-4">
          <div class="col-md-4">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <i class="bi bi-globe display-4 text-primary"></i>

                <h4 class="mt-3">Web Development</h4>

                <p class="text-muted">
                  Learn HTML, CSS, JavaScript, Express, React and Node.js
                </p>
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <i class="bi bi-phone display-4 text-success"></i>

                <h4 class="mt-3">Mobile Development</h4>

                <p class="text-muted">Build Android and iOS applications</p>
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <i class="bi bi-cpu display-4 text-danger"></i>

                <h4 class="mt-3">Artificial Intelligence</h4>

                <p class="text-muted">
                  Machine Learning, NLP and Computer Vision
                </p>
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <i class="bi bi-bar-chart display-4 text-warning"></i>

                <h4 class="mt-3">Data Science</h4>

                <p class="text-muted">Analyze data using Python and SQL</p>
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <i class="bi bi-cloud display-4 text-info"></i>

                <h4 class="mt-3">Cloud Computing</h4>

                <p class="text-muted">AWS, Docker and Kubernetes</p>
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <div class="card shadow-sm h-100">
              <div class="card-body text-center">
                <i class="bi bi-shield-lock display-4 text-secondary"></i>

                <h4 class="mt-3">Cyber Security</h4>

                <p class="text-muted">Network Security and Ethical Hacking</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- CTA -->

    <section class="bg-dark text-white py-5">
      <div class="container text-center">
        <h1 class="fw-bold">Ready to Start Learning?</h1>

        <p class="lead mb-4">
          Join BilgeHub and improve your programming skills today.
        </p>

        <a href="/register" class="btn btn-warning btn-lg rounded-pill px-5">
          Create Free Account
        </a>
      </div>
    </section>

    <!-- Footer -->

    <footer class="bg-black text-white py-4">
      <div class="container">
        <div class="row">
          <div class="col-md-6">
            <h4 class="fw-bold">🎓 BilgeHub</h4>

            <p class="text-secondary">
              Online Learning Platform for Future Developers.
            </p>
          </div>

          <div class="col-md-6 text-md-end">
            <p class="mb-0">© 2026 BilgeHub. All Rights Reserved.</p>
          </div>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
